# Production environment — copy to .env.production on the VPS and fill in all values.
# Never commit .env.production to git.

# Random secret — generate with: openssl rand -hex 32
CODEX_API_KEY=

# Full public URL of the app including subdomain
FRONTEND_URL=https://codex.yourdomain.com

# Anthropic Claude API key
ANTHROPIC_API_KEY=

# Google OAuth credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
