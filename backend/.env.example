# Copy to .env and set values. Required for API access:
CODEX_API_KEY=change-me-in-production

# SQLite path is fixed relative to backend: database/codex.sqlite

# Optional frontend base URL used for OAuth callback redirect target (e.g. https://app.example.com)
# If empty, backend falls back to Origin/Referer headers, then localhost dev defaults.
FRONTEND_URL=

# Optional Google OAuth (Calendar/Gmail). If both are set here, they override Settings UI values.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Explicit redirect URI for the login OAuth callback.
# Must match exactly what is registered in Google Cloud Console.
# Default for Docker Compose dev: http://localhost:8180/api/auth/callback
GOOGLE_REDIRECT_URI=
