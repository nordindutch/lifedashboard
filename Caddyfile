# TLS is terminated by host Apache; Caddy serves HTTP only on localhost:8082.
{
    auto_https off
}

# :80 (not a hostname) — with a hostname site address Caddy binds the HTTPS
# port even when auto_https is off, leaving :80 unbound and the compose
# mapping 127.0.0.1:8082->80 dead.
:80 {
    handle /api/* {
        reverse_proxy php:80
    }

    # Vite hashed files — safe to cache forever
    handle /assets/* {
        root * /srv/frontend
        header Cache-Control "public, max-age=31536000, immutable"
        file_server
    }

    handle {
        root * /srv/frontend
        try_files {path} /index.html
        # SPA shell must not be cached aggressively or users keep stale index + old JS references
        header Cache-Control "no-cache, no-store, must-revalidate"
        file_server
    }

    header {
        X-Frame-Options DENY
        X-Content-Type-Options nosniff
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }

    encode gzip
}
