# Copy to `.env` next to docker-compose.yml for variable substitution.
# Use the same CODEX_API_KEY in backend/.env so the API accepts requests from the UI.

CODEX_API_KEY=dev-codex-key

# Published ports are fixed in docker-compose.yml: UI http://localhost:5273 → Vite 5173, API http://localhost:8180 → Apache 80.
