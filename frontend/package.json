{
  "name": "project-codex-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:tauri": "vite --mode tauri",
    "build": "tsc --noEmit && vite build",
    "build:tauri": "tsc --noEmit && vite build --mode tauri",
    "build:android": "tsc --noEmit && vite build --mode android",
    "cap:sync": "cd .. && npx --prefix frontend cap sync android",
    "cap:open": "cd .. && npx --prefix frontend cap open android",
    "preview": "vite preview",
    "tauri:dev": "cd .. && tauri dev",
    "tauri:build": "cd .. && tauri build"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
