# Dev: Vite proxies /api to PHP — leave base empty or set full API URL for native builds
VITE_API_BASE_URL=

# Tauri / Capacitor release builds: REQUIRED — HTTPS origin of your PHP API (no trailing slash).
# Put this in .env.tauri.local (gitignored) or CI env when running: npm run build:tauri
# VITE_API_BASE_URL=https://codex.example.com

# For Tauri dev against local PHP:
# VITE_API_BASE_URL=http://localhost:8180

VITE_CODEX_API_KEY=

# Docker Compose sets these in the frontend service (see docker-compose.yml):
# DOCKER=true, VITE_API_PROXY_TARGET=http://php:80, VITE_CODEX_API_KEY=<same as backend CODEX_API_KEY>
