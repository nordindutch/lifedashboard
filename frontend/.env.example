# Dev: Vite proxies /api to PHP — leave base empty or set full API URL for native builds
VITE_API_BASE_URL=
VITE_CODEX_API_KEY=

# Docker Compose sets these in the frontend service (see docker-compose.yml):
# DOCKER=true, VITE_API_PROXY_TARGET=http://php:80, VITE_CODEX_API_KEY=<same as backend CODEX_API_KEY>
